# Ollama service URL
# Docker:    http://ollama:11434  (set automatically by docker-compose.yml)
# Local dev: http://localhost:11434  (default)
OLLAMA_BASE_URL=http://localhost:11434

# Models — must be pulled in Ollama before starting the app
EXPLAINER_MODEL=gemma3:4b
EMBED_MODEL=nomic-embed-text:latest
