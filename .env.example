# Ollama service URL
# Docker:    http://ollama:11434  (set automatically by docker-compose.yml)
# Local dev: http://localhost:11434  (default)
OLLAMA_BASE_URL=http://localhost:11434

# Models — must be pulled in Ollama before starting the app
EXPLAINER_MODEL=gemma3:4b
EMBED_MODEL=nomic-embed-text:latest

# Groq cloud LLM (optional — leave blank to use Ollama only)
# Get a free key at https://console.groq.com
GROQ_API_KEY=key

# Comma-separated list of Groq models shown in the UI dropdown
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,gemma2-9b-it,mixtral-8x7b-32768
